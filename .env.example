# ===========================================
# 期末复习刷题系统 - 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ===========================================

# ----- 数据库配置 -----
DB_PASSWORD=your-database-password

# ----- JWT 配置 -----
JWT_SECRET=your-jwt-secret-key-min-32-chars

# ----- DeepSeek AI 配置（可选，用于 AI 出题功能）-----
DEEPSEEK_API_KEY=your-deepseek-api-key
